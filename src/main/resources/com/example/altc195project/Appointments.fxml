<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="672.0" prefWidth="1038.0" xmlns="http://javafx.com/javafx/17.0.6" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.altc195project.controller.Appointments">
   <children>
      <TableView fx:id="appointmentTable" layoutX="14.0" layoutY="14.0" prefHeight="464.0" prefWidth="1010.0" style="-fx-font-family: 'consolas'; -fx-font-size: 10pt;">
        <columns>
          <TableColumn fx:id="appointmentIdCol" prefWidth="112.0" text="Appointment ID" />
          <TableColumn fx:id="appointmentTitleCol" prefWidth="61.0" text="Title" />
            <TableColumn fx:id="appointmentDescrCol" prefWidth="99.0" text="Description" />
            <TableColumn fx:id="appointmentLocationCol" prefWidth="79.0" text="Location" />
            <TableColumn fx:id="appointmentStylistCol" prefWidth="89.0" text="Stylist" />
            <TableColumn fx:id="appointmentTypeCol" prefWidth="91.0" text="Type" />
            <TableColumn fx:id="appointmentStartCol" prefWidth="169.0" text="Start Date/Time" />
            <TableColumn fx:id="appointmentEndCol" prefWidth="159.0" text="End Date/Time" />
            <TableColumn fx:id="appointmentClientIdCol" prefWidth="150.0" text="Client ID" />
        </columns>
      </TableView>
      <GridPane layoutX="14.0" layoutY="548.0" prefHeight="62.0" prefWidth="445.0">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" maxWidth="236.0" minWidth="10.0" prefWidth="138.0" />
          <ColumnConstraints hgrow="SOMETIMES" maxWidth="195.0" minWidth="10.0" prefWidth="142.0" />
            <ColumnConstraints hgrow="SOMETIMES" maxWidth="172.0" minWidth="10.0" prefWidth="165.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Button fx:id="appointmentAddLabel" mnemonicParsing="false" onAction="#actionAppointmentAdd" prefHeight="40.0" prefWidth="85.0" text="Add">
               <font>
                  <Font name="Consolas" size="14.0" />
               </font></Button>
            <Button fx:id="appointmentUpdateLabel" mnemonicParsing="false" onAction="#actionAppointmentUpdate" prefHeight="40.0" prefWidth="85.0" text="Update" GridPane.columnIndex="1">
               <font>
                  <Font name="Consolas" size="14.0" />
               </font></Button>
            <Button fx:id="appointmentDeleteLabel" mnemonicParsing="false" onAction="#actionAppointmentDelete" prefHeight="40.0" prefWidth="85.0" text="Delete" GridPane.columnIndex="2">
               <font>
                  <Font name="Consolas" size="14.0" />
               </font></Button>
         </children>
      </GridPane>
      <Button layoutX="851.0" layoutY="559.0" mnemonicParsing="false" onAction="#backMainMenu" prefHeight="40.0" prefWidth="123.0" text="Back to Menu">
         <font>
            <Font name="Consolas" size="14.0" />
         </font></Button>
      <GridPane fx:id="appointmentButtons" layoutX="17.0" layoutY="479.0" prefHeight="53.0" prefWidth="560.0">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" maxWidth="219.0" minWidth="10.0" prefWidth="204.0" />
          <ColumnConstraints hgrow="SOMETIMES" maxWidth="237.0" minWidth="10.0" prefWidth="135.0" />
            <ColumnConstraints hgrow="SOMETIMES" maxWidth="286.0" minWidth="10.0" prefWidth="208.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <RadioButton fx:id="allAppointmentsButton" mnemonicParsing="false" onAction="#allAppointments" prefHeight="24.0" prefWidth="177.0" text="All Appointments">
               <font>
                  <Font name="Consolas" size="14.0" />
               </font>
            </RadioButton>
            <RadioButton fx:id="weekAppointmentsButton" mnemonicParsing="false" onAction="#weekAppointments" prefHeight="19.0" prefWidth="73.0" text="Week" GridPane.columnIndex="1">
               <font>
                  <Font name="Consolas" size="14.0" />
               </font>
            </RadioButton>
            <RadioButton fx:id="monthAppointmentsButton" mnemonicParsing="false" onAction="#monthAppointments" text="Month" GridPane.columnIndex="2">
               <font>
                  <Font name="Consolas" size="14.0" />
               </font>
            </RadioButton>
         </children>
      </GridPane>
   </children>
</AnchorPane>
