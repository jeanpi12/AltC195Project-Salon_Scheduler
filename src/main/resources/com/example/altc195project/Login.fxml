<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" prefHeight="589.0" prefWidth="609.0" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.6" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.altc195project.controller.Login">
  <padding>
    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
  </padding>
   <AnchorPane prefHeight="562.0" prefWidth="584.0">
      <children>
         <Label fx:id="loginTitle" layoutX="210.0" layoutY="85.0" prefHeight="57.0" prefWidth="149.0" text="Login">
            <font>
               <Font name="Consolas" size="48.0" />
            </font>
         </Label>
         <GridPane layoutX="148.0" layoutY="182.0" prefHeight="216.0" prefWidth="355.0">
           <columnConstraints>
             <ColumnConstraints hgrow="SOMETIMES" maxWidth="242.0" minWidth="10.0" prefWidth="113.0" />
             <ColumnConstraints hgrow="SOMETIMES" maxWidth="382.0" minWidth="10.0" prefWidth="221.0" />
           </columnConstraints>
           <rowConstraints>
             <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
             <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
             <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
           </rowConstraints>
            <children>
               <Label fx:id="labelUserID" text="User ID:">
                  <font>
                     <Font name="Consolas" size="18.0" />
                  </font>
               </Label>
               <TextField fx:id="txtFieldUserID" prefHeight="29.0" prefWidth="337.0" promptText="Enter UserID" GridPane.columnIndex="1">
                  <font>
                     <Font name="Consolas Italic" size="12.0" />
                  </font>
               </TextField>
               <Label fx:id="labelPassword" text="Password:" GridPane.rowIndex="1">
                  <font>
                     <Font name="Consolas" size="18.0" />
                  </font>
               </Label>
               <PasswordField fx:id="txtFieldPassword" prefHeight="29.0" prefWidth="337.0" promptText="Enter Password" GridPane.columnIndex="1" GridPane.rowIndex="1">
                  <font>
                     <Font name="Consolas Italic" size="12.0" />
                  </font>
               </PasswordField>
               <Button fx:id="loginButton" mnemonicParsing="false" onAction="#actionLoginButton" prefHeight="33.0" prefWidth="101.0" text="Login" GridPane.rowIndex="2">
                  <font>
                     <Font name="Consolas" size="14.0" />
                  </font>
               </Button>
               <Button fx:id="cancelButton" mnemonicParsing="false" onAction="#actionCancelButton" prefHeight="33.0" prefWidth="101.0" text="Cancel" GridPane.columnIndex="1" GridPane.rowIndex="2">
                  <font>
                     <Font name="Consolas" size="14.0" />
                  </font>
               </Button>
            </children>
         </GridPane>
         <Label layoutX="240.0" layoutY="433.0" text="Location:">
            <font>
               <Font name="Consolas" size="16.0" />
            </font>
         </Label>
         <Label fx:id="labelLocation" alignment="CENTER" layoutX="115.0" layoutY="457.0" prefHeight="22.0" prefWidth="331.0" text="Label" textAlignment="CENTER">
            <font>
               <Font name="Consolas" size="16.0" />
            </font>
         </Label>
      </children></AnchorPane>
   <cursor>
      <Cursor fx:constant="DEFAULT" />
   </cursor>
</VBox>
